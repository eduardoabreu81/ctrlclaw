# CtrlClaw Environment Configuration
# Copy this file to .env.local and adjust values for your setup

# ============================================
# Deployment Scenario
# ============================================
# Options: local | vps | tunnel
NEXT_PUBLIC_DEPLOYMENT_SCENARIO=local

# ============================================
# Backend Configuration
# ============================================
# Local development with mock backend
NEXT_PUBLIC_BACKEND_HTTP_URL=http://localhost:3001
NEXT_PUBLIC_BACKEND_WS_URL=ws://localhost:3001

# For VPS deployment (example)
# NEXT_PUBLIC_BACKEND_HTTP_URL=https://api.yourdomain.com
# NEXT_PUBLIC_BACKEND_WS_URL=wss://api.yourdomain.com

# For secure tunnel (example)
# NEXT_PUBLIC_BACKEND_HTTP_URL=https://claw.yourdomain.com
# NEXT_PUBLIC_BACKEND_WS_URL=wss://claw.yourdomain.com

# ============================================
# Security Configuration
# ============================================
# Allow localhost connections in CSP (development only)
CSP_ALLOW_LOCAL=true

# ============================================
# Optional: Analytics (not implemented yet)
# ============================================
# NEXT_PUBLIC_ANALYTICS_ID=
